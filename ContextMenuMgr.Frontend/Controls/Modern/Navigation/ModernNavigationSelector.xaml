<UserControl
    x:Class="ContextMenuMgr.Frontend.Controls.Modern.Navigation.ModernNavigationSelector"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root"
    Focusable="False">
    <UserControl.Resources>
        <Style x:Key="ModernNavigationSelectorItemStyle" TargetType="ListBoxItem">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Margin" Value="4,1" />
            <Setter Property="Padding" Value="12,8,10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NavigationViewItemForeground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border
                            x:Name="ItemRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                            <Grid>
                                <Border
                                    x:Name="SelectionIndicator"
                                    Width="3"
                                    Height="18"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource NavigationViewSelectionIndicatorForeground}"
                                    CornerRadius="2"
                                    Opacity="0" />
                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource NavigationViewItemBackgroundPointerOver}" />
                                <Setter Property="Foreground" Value="{DynamicResource NavigationViewItemForegroundPointerOver}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource NavigationViewItemBackgroundSelected}" />
                                <Setter TargetName="SelectionIndicator" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="{DynamicResource NavigationViewItemForeground}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource NavigationViewItemBackgroundPointerOver}" />
                            </MultiTrigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseCaptured" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource NavigationViewItemBackgroundPressed}" />
                                <Setter Property="Foreground" Value="{DynamicResource NavigationViewItemForegroundPressed}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border
        Background="{DynamicResource LayerFillColorAltBrush}"
        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="HeaderPanel" Margin="12,12,12,8">
                <ContentPresenter
                    x:Name="HeaderPresenter"
                    Content="{Binding Header, ElementName=Root}"
                    TextElement.FontSize="15"
                    TextElement.FontWeight="SemiBold"
                    TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <ContentPresenter
                    x:Name="DescriptionPresenter"
                    Margin="0,6,0,0"
                    Content="{Binding Description, ElementName=Root}"
                    TextElement.FontSize="12"
                    TextElement.Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <ListBox
                x:Name="PART_ListBox"
                Grid.Row="1"
                Padding="0,0,0,6"
                Background="Transparent"
                BorderThickness="0"
                ItemContainerStyle="{StaticResource ModernNavigationSelectorItemStyle}"
                ItemTemplate="{Binding ItemTemplate, ElementName=Root}"
                ItemsSource="{Binding ItemsSource, ElementName=Root}"
                SelectedItem="{Binding SelectedItem, ElementName=Root, Mode=TwoWay}"
                SelectionChanged="OnSelectionChanged"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </Grid>
    </Border>
</UserControl>
