<Page
    x:Class="ContextMenuMgr.Frontend.Views.ApprovalsPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewModels="clr-namespace:ContextMenuMgr.Frontend.ViewModels"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Background="{DynamicResource LayerFillColorAltBrush}"
            Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <ui:TextBlock
                    FontSize="24"
                    FontWeight="SemiBold"
                    Text="{Binding Title}" />
                <ui:TextBlock
                    Margin="0,6,0,0"
                    Opacity="0.72"
                    Text="{Binding Description}" />
                <StackPanel Margin="0,12,0,0">
                    <ui:TextBlock
                        Margin="0,0,0,6"
                        FontSize="12"
                        Opacity="0.72"
                        Text="{Binding SearchLabel}" />
                    <TextBox
                        MinWidth="220"
                        Padding="10,6"
                        Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <ListBox
            Grid.Row="1"
            Background="Transparent"
            BorderThickness="0"
            ItemContainerStyle="{StaticResource ScrollableListBoxItemStyle}"
            ItemsSource="{Binding ItemsView}"
            ScrollViewer.CanContentScroll="True"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type viewModels:ApprovalQueueItemViewModel}">
                    <Border
                        Margin="0,0,0,10"
                        Padding="12"
                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Width="28"
                                    Height="28"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Image
                                        Width="20"
                                        Height="20"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Source="{Binding IconSource}" />
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <ui:TextBlock
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Text="{Binding DisplayName}" />
                                    <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding CategoryTags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type viewModels:ApprovalTagChipViewModel}">
                                                <Border
                                                    Margin="0,0,6,4"
                                                    Padding="8,2"
                                                    Background="{DynamicResource AccentFillColorSecondaryBrush}"
                                                    CornerRadius="4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsWindows11Tag}" Value="True">
                                                                    <Setter Property="Background" Value="#1F6A3BFF" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <ui:TextBlock FontSize="11">
                                                        <ui:TextBlock.Style>
                                                            <Style TargetType="ui:TextBlock">
                                                                <Setter Property="Text" Value="{Binding Text}" />
                                                                <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                                                            </Style>
                                                        </ui:TextBlock.Style>
                                                    </ui:TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ui:TextBlock
                                        Margin="0,3,0,0"
                                        FontSize="11"
                                        Opacity="0.6"
                                        Text="{Binding KeyName}"
                                        Visibility="{Binding ShowKeyName, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>
                            </Grid>
                            <ui:TextBlock
                                Margin="0,6,0,0"
                                FontFamily="Consolas"
                                FontSize="11"
                                Opacity="0.72"
                                Text="{Binding RegistryPath}" />
                            <ui:TextBlock
                                Margin="0,8,0,0"
                                Opacity="0.78"
                                Text="{Binding Notes}"
                                TextWrapping="Wrap"
                                Visibility="{Binding ShowNotes, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                <ui:Button
                                    Margin="0,0,8,0"
                                    Padding="12,5"
                                    Command="{Binding DataContext.AllowGroupCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding}"
                                    Content="{Binding DataContext.AllowText, RelativeSource={RelativeSource AncestorType=Page}}"
                                    Icon="{ui:SymbolIcon Symbol=Checkmark24}"
                                    IsEnabled="{Binding CanReviewApproval}" />
                                <ui:Button
                                    Margin="8,0,0,0"
                                    Padding="12,5"
                                    Appearance="Secondary"
                                    Command="{Binding DataContext.DenyGroupCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding}"
                                    Content="{Binding DataContext.KeepDisabledText, RelativeSource={RelativeSource AncestorType=Page}}"
                                    Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                                    IsEnabled="{Binding CanReviewApproval}" />
                                <Grid Margin="10,0,0,0" Visibility="{Binding CanRemove, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ui:Flyout IsOpen="{Binding IsApprovalRemoveFlyoutOpen, Mode=TwoWay}" Placement="Top">
                                        <StackPanel Width="280">
                                            <ui:TextBlock
                                                HorizontalAlignment="Left"
                                                Text="{Binding ApprovalRemoveConfirmationText}"
                                                TextWrapping="Wrap" />
                                            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                                <ui:Button
                                                    Margin="0,0,8,0"
                                                    Appearance="Primary"
                                                    Command="{Binding DataContext.ConfirmRemoveCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"
                                                    Content="{Binding DataContext.ConfirmRemoveText, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    Icon="{ui:SymbolIcon Symbol=Delete24}" />
                                                <ui:Button
                                                    Appearance="Secondary"
                                                    Command="{Binding CloseApprovalRemoveFlyoutCommand}"
                                                    Content="{Binding DataContext.CancelText, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    Icon="{ui:SymbolIcon Symbol=Dismiss24}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </ui:Flyout>
                                    <ui:Button
                                        MinWidth="88"
                                        Padding="12,5"
                                        Appearance="Secondary"
                                        Command="{Binding DataContext.OpenRemoveCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Content="{Binding DataContext.RemoveText, RelativeSource={RelativeSource AncestorType=Page}}"
                                        Icon="{ui:SymbolIcon Symbol=Delete24}" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
