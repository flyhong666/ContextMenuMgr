<Page
    x:Class="ContextMenuMgr.Frontend.Views.SettingsPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <WrapPanel Margin="10,10,0,0" Orientation="Horizontal">
        <Border
            Margin="0,0,10,10"
            Background="{DynamicResource ControlFillColorSecondaryBrush}"
            Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <ui:TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="{Binding LanguageLabel}" />
                <ComboBox
                    Width="220"
                    Margin="0,12,0,0"
                    DisplayMemberPath="DisplayName"
                    ItemsSource="{Binding AvailableLanguages}"
                    SelectedItem="{Binding SelectedLanguage}" />
            </StackPanel>
        </Border>

        <Border
            Margin="0,0,10,10"
            Background="{DynamicResource ControlFillColorSecondaryBrush}"
            Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <ui:TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="{Binding ThemeLabel}" />
                <ComboBox
                    Width="220"
                    Margin="0,12,0,0"
                    DisplayMemberPath="DisplayName"
                    ItemsSource="{Binding AvailableThemes}"
                    SelectedItem="{Binding SelectedTheme}" />
            </StackPanel>
        </Border>

        <Border
            Margin="0,0,10,10"
            Background="{DynamicResource ControlFillColorSecondaryBrush}"
            Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <ui:TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="{Binding LogLevelLabel}" />
                <ComboBox
                    Width="220"
                    Margin="0,12,0,0"
                    DisplayMemberPath="DisplayName"
                    ItemsSource="{Binding AvailableLogLevels}"
                    SelectedItem="{Binding SelectedLogLevel}" />
            </StackPanel>
        </Border>

        <Border
            Margin="0,0,10,10"
            Background="{DynamicResource ControlFillColorSecondaryBrush}"
            Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <ui:TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="{Binding StartupBehaviorTitle}" />
                <ui:ToggleSwitch
                    Margin="0,12,0,0"
                    Content="{Binding AutoStartOnLoginLabel}"
                    IsChecked="{Binding AutoStartOnLogin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <ui:TextBlock
                    Margin="0,8,0,0"
                    Opacity="0.72"
                    Text="{Binding AutoStartOnLoginDescription}"
                    TextWrapping="Wrap" />
                <ui:ToggleSwitch
                    Margin="0,16,0,0"
                    Content="{Binding KeepBackgroundAfterCloseLabel}"
                    IsChecked="{Binding KeepBackgroundAfterClose, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <ui:TextBlock
                    Margin="0,8,0,0"
                    Opacity="0.72"
                    Text="{Binding KeepBackgroundAfterCloseDescription}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border
            Margin="0,0,10,10"
            Background="{DynamicResource ControlFillColorSecondaryBrush}"
            Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <ui:TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="{Binding ProtectionTitle}" />
                <Grid Margin="0,12,0,0">
                    <ui:Flyout
                        IsOpen="{Binding IsRegistryProtectionWarningFlyoutOpen, Mode=TwoWay}"
                        Placement="Top">
                        <StackPanel Width="340">
                            <ui:TextBlock
                                FontWeight="SemiBold"
                                Text="{Binding RegistryProtectionWarningTitle}"
                                TextWrapping="Wrap" />
                            <ui:TextBlock
                                Margin="0,8,0,0"
                                Opacity="0.82"
                                Text="{Binding RegistryProtectionWarningText}"
                                TextWrapping="Wrap" />
                            <StackPanel
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <ui:Button
                                    Margin="0,0,8,0"
                                    Appearance="Primary"
                                    Command="{Binding ConfirmRegistryProtectionWarningCommand}"
                                    Content="{Binding RegistryProtectionWarningConfirmText}"
                                    Icon="{ui:SymbolIcon Symbol=Checkmark24}" />
                                <ui:Button
                                    Appearance="Secondary"
                                    Command="{Binding CloseRegistryProtectionWarningFlyoutCommand}"
                                    Content="{Binding RegistryProtectionWarningCloseText}"
                                    Icon="{ui:SymbolIcon Symbol=Dismiss24}" />
                            </StackPanel>
                        </StackPanel>
                    </ui:Flyout>

                    <ui:ToggleSwitch
                        Content="{Binding LockNewContextMenuItemsLabel}"
                        IsChecked="{Binding LockNewContextMenuItems, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <ui:TextBlock
                    Margin="0,8,0,0"
                    Opacity="0.72"
                    Text="{Binding LockNewContextMenuItemsDescription}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border
            Margin="0,0,10,10"
            Background="{DynamicResource ControlFillColorSecondaryBrush}"
            Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <ui:TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="{Binding ServiceSettingsTitle}" />
                <ui:TextBlock
                    Margin="0,10,0,0"
                    Opacity="0.72"
                    Text="{Binding ServiceStateText}" />
                <WrapPanel Margin="0,16,0,0">
                    <ui:Button
                        Margin="0,0,12,12"
                        Padding="16,8"
                        Command="{Binding InstallOrRepairServiceCommand}"
                        Content="{Binding InstallOrRepairServiceText}"
                        Icon="{ui:SymbolIcon Symbol=ArrowDownload24}" />
                    <Grid Margin="0,0,12,12">
                        <ui:Flyout
                            Margin="0,0,0,25"
                            IsOpen="{Binding IsUninstallFlyoutOpen, Mode=TwoWay}"
                            Placement="Top">
                            <StackPanel Width="300">
                                <ui:TextBlock
                                    HorizontalAlignment="Left"
                                    Text="{Binding UninstallFlyoutText}"
                                    TextWrapping="Wrap" />
                                <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                    <ui:Button
                                        Margin="0,0,8,0"
                                        Appearance="Primary"
                                        Command="{Binding ConfirmUninstallServiceCommand}"
                                        Content="{Binding ConfirmUninstallText}"
                                        Icon="{ui:SymbolIcon Symbol=Delete24}" />
                                    <ui:Button
                                        Appearance="Secondary"
                                        Command="{Binding CloseUninstallFlyoutCommand}"
                                        Content="{Binding CancelText}"
                                        Icon="{ui:SymbolIcon Symbol=Dismiss24}" />
                                </StackPanel>
                            </StackPanel>
                        </ui:Flyout>
                        <ui:Button
                            Padding="16,8"
                            Command="{Binding OpenUninstallServiceFlyoutCommand}"
                            Content="{Binding UninstallServiceText}"
                            Icon="{ui:SymbolIcon Symbol=Delete24}" />
                    </Grid>
                    <Button
                        Margin="0,0,12,12"
                        Padding="16,8"
                        Command="{Binding RefreshServiceStateCommand}"
                        Content="{Binding RefreshText}" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border
            Margin="0,0,10,10"
            Background="{DynamicResource ControlFillColorSecondaryBrush}"
            Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <ui:TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="{Binding LocalFilesTitle}" />
                <WrapPanel Margin="0,16,0,0">
                    <ui:Button
                        Margin="0,0,12,12"
                        Padding="16,8"
                        Command="{Binding OpenLogsFolderCommand}"
                        Content="{Binding OpenLogsFolderText}"
                        Icon="{ui:SymbolIcon Symbol=DocumentText24}" />
                    <ui:Button
                        Margin="0,0,12,12"
                        Padding="16,8"
                        Command="{Binding OpenStateFolderCommand}"
                        Content="{Binding OpenStateFolderText}"
                        Icon="{ui:SymbolIcon Symbol=Database24}" />
                    <ui:Button
                        Margin="0,0,12,12"
                        Padding="16,8"
                        Command="{Binding OpenConfigFolderCommand}"
                        Content="{Binding OpenConfigFolderText}"
                        Icon="{ui:SymbolIcon Symbol=FolderOpen24}" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border
            Margin="0,0,10,10"
            Background="{DynamicResource ControlFillColorSecondaryBrush}"
            Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <ui:TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="{Binding DebugToolsTitle}" />
                <WrapPanel Margin="0,16,0,0">
                    <ui:Button
                        Margin="0,0,12,12"
                        Padding="16,8"
                        Command="{Binding ResetStateDatabaseCommand}"
                        Content="{Binding ResetStateDatabaseText}"
                        Icon="{ui:SymbolIcon Symbol=Database24}" />
                    <ui:Button
                        Margin="0,0,12,12"
                        Padding="16,8"
                        Command="{Binding ResetSettingsCommand}"
                        Content="{Binding ResetSettingsText}"
                        Icon="{ui:SymbolIcon Symbol=Settings24}" />
                    <ui:Button
                        Margin="0,0,12,12"
                        Padding="16,8"
                        Command="{Binding ClearAllLogsCommand}"
                        Content="{Binding ClearAllLogsText}"
                        Icon="{ui:SymbolIcon Symbol=Delete24}" />
                </WrapPanel>
            </StackPanel>
        </Border>
        <Border
            Margin="0,0,10,10"
            Background="{DynamicResource ControlFillColorSecondaryBrush}"
            Style="{StaticResource CardBorderStyle}">
            <Grid MinWidth="260">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border
                        Width="40"
                        Height="40"
                        Margin="0,0,12,0"
                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                        CornerRadius="10">
                        <ui:ImageIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Source="/Assets/AppIcon.png" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <ui:TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="Context Menu Manager Plus" />
                        <ui:TextBlock
                            Margin="0,4,0,0"
                            Opacity="0.72"
                            Text="{Binding LicenseText}" />
                    </StackPanel>
                </StackPanel>

                <Border
                    Grid.Row="1"
                    Margin="0,16,0,0"
                    Padding="12"
                    Background="{DynamicResource ControlFillColorTertiaryBrush}"
                    CornerRadius="10">
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <ui:TextBlock Opacity="0.72" Text="{Binding VersionLabel}" />
                            <ui:TextBlock
                                Margin="0,4,0,0"
                                FontFamily="Consolas"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="{Binding VersionText}" />
                        </StackPanel>
                        <ui:SymbolIcon
                            VerticalAlignment="Center"
                            DockPanel.Dock="Right"
                            FontSize="18"
                            Opacity="0.72"
                            Symbol="Tag24" />
                    </DockPanel>
                </Border>

                <ui:HyperlinkButton
                    Grid.Row="2"
                    Margin="0,14,0,0"
                    HorizontalAlignment="Left"
                    Content="{Binding RepositoryUrl}"
                    Icon="{ui:SymbolIcon Symbol=Open24}"
                    NavigateUri="{Binding RepositoryUrl}" />
            </Grid>
        </Border>
    </WrapPanel>
</Page>
