<UserControl
    x:Class="ContextMenuMgr.Frontend.Views.FileTypesPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:ContextMenuMgr.Frontend.Views">
    <Grid>
        <TabControl x:Name="MainTabControl" Margin="0,8,0,0">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Document24" />
                        <TextBlock Text="{Binding ShortcutTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <views:SceneBrowserView DataContext="{Binding ShortcutTab}" />
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="AppsAddIn24" />
                        <TextBlock Text="{Binding UwpShortcutTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <views:SceneBrowserView DataContext="{Binding UwpShortcutTab}" />
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="WindowConsole20" />
                        <TextBlock Text="{Binding ExecutableTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <views:SceneBrowserView DataContext="{Binding ExecutableTab}" />
                </Grid>
            </TabItem>
            <TabItem IsSelected="True">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="DocumentText24" />
                        <TextBlock Text="{Binding CustomExtensionTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <views:SceneBrowserView DataContext="{Binding CustomExtensionTab}" />
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="TextNumberListLtr24" />
                        <TextBlock Text="{Binding PerceivedTypeTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <views:SceneBrowserView DataContext="{Binding PerceivedTypeTab}" />
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Folder24" />
                        <TextBlock Text="{Binding DirectoryTypeTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <views:SceneBrowserView DataContext="{Binding DirectoryTypeTab}" />
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Document24" />
                        <TextBlock Text="{Binding UnknownTypeTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <views:SceneBrowserView DataContext="{Binding UnknownTypeTab}" />
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Search24" />
                        <TextBlock Text="{Binding MenuAnalysisTitle}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Background="{DynamicResource LayerFillColorAltBrush}" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock
                                FontSize="22"
                                FontWeight="SemiBold"
                                Text="{Binding MenuAnalysisTitle}" />
                            <TextBlock
                                Margin="0,6,0,0"
                                Opacity="0.72"
                                Text="{Binding MenuAnalysisDescription}"
                                TextWrapping="Wrap" />
                            <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                <ui:Button
                                    Command="{Binding AnalyzeFileCommand}"
                                    Content="{Binding AnalyzeFileText}"
                                    Icon="{ui:SymbolIcon Symbol=DocumentSearch24}" />
                                <ui:Button
                                    Margin="8,0,0,0"
                                    Command="{Binding AnalyzeFolderCommand}"
                                    Content="{Binding AnalyzeFolderText}"
                                    Icon="{ui:SymbolIcon Symbol=FolderSync24}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <ItemsControl
                        Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding AnalysisResults}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="12"
                                    Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <DockPanel>
                                        <ui:Button
                                            Padding="12,5"
                                            Command="{Binding DataContext.ApplyAnalysisResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding DataContext.JumpText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            DockPanel.Dock="Right"
                                            Icon="{ui:SymbolIcon Symbol=ArrowRight24}" />
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Text="{Binding DisplayName}" />
                                            <TextBlock
                                                Margin="0,6,0,0"
                                                Opacity="0.72"
                                                Text="{Binding Reason}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
