<Page
    x:Class="ContextMenuMgr.Frontend.Views.ApplicationGroupsPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:ContextMenuMgr.Frontend.Behaviors"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Background="Transparent"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel>
            <ui:TextBlock FontSize="28" FontWeight="SemiBold" Text="{Binding Title}" />
            <ui:TextBlock Margin="0,6,0,0" Opacity="0.72" Text="{Binding Description}" TextWrapping="Wrap" />
        </StackPanel>
        <TextBox Grid.Row="1" Margin="0,18,0,14" Padding="10,7" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding SearchLabel}" />
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Groups}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,12" Padding="16" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <DockPanel>
                                <ui:Button DockPanel.Dock="Right" Appearance="Secondary" Command="{Binding DisableAllCommand}" Content="{Binding DisableAllText}" />
                                <StackPanel>
                                    <ui:TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Identity}" TextWrapping="Wrap" />
                                    <ui:TextBlock Margin="0,3,0,0" Opacity="0.65" Text="{Binding CountText}" />
                                </StackPanel>
                            </DockPanel>
                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,8,0,0" Padding="14" Style="{StaticResource CardBorderStyle}" Opacity="{Binding CardOpacity}" Tag="{Binding Id}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="34" Height="34" Margin="0,0,10,0" Background="{DynamicResource SubtleFillColorSecondaryBrush}" CornerRadius="6">
                                                            <Image Margin="5" Source="{Binding IconSource}" Stretch="Uniform" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1">
                                                            <WrapPanel>
                                                                <ui:TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                                                <Border Height="23" Margin="8,0,0,0" Padding="8,2" CornerRadius="4">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                                    <Setter Property="Background" Value="{DynamicResource SystemFillColorNeutralBackgroundBrush}" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <ui:TextBlock VerticalAlignment="Center" FontSize="11" Text="{Binding StateLabel}" />
                                                                </Border>
                                                                <ui:Button Margin="10,0,0,0" Appearance="Secondary" Command="{Binding DeepAnalyzeMenuItemCommand}" Content="{Binding DeepAnalyzeMenuItemText}" ToolTip="{Binding DeepAnalyzeMenuItemTooltip}" Visibility="{Binding CanDeepAnalyzeMenuItem, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                            </WrapPanel>
                                                            <ui:TextBlock Margin="0,3,0,0" FontSize="11" Opacity="0.65" Text="{Binding CategoryName}" />
                                                            <ui:TextBlock Margin="0,2,0,0" FontSize="11" Opacity="0.6" Text="{Binding KeyName}" Visibility="{Binding ShowKeyName, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <ui:TextBlock Margin="0,6,0,0" FontFamily="Consolas" FontSize="11" Opacity="0.72" Text="{Binding RegistryPath}" TextWrapping="Wrap" />
                                                    <ui:TextBlock Margin="0,6,0,0" FontFamily="Consolas" FontSize="11" Opacity="0.72" Text="{Binding InlineCommandText}" TextWrapping="Wrap" Visibility="{Binding ShowInlineCommandText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                    <ui:TextBlock Margin="0,8,0,0" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" Text="{Binding UserNoteDisplay}" TextWrapping="Wrap" Visibility="{Binding HasUserNote, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                    <ui:TextBlock Margin="0,8,0,0" Opacity="0.78" Text="{Binding Notes}" TextWrapping="Wrap" Visibility="{Binding ShowNotes, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="12,0,0,0" HorizontalAlignment="Right">
                                                    <ui:ToggleSwitch MinWidth="72" Margin="0,0,0,8" Content="{Binding ToggleLabel}" IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanToggle}" Visibility="{Binding ShowToggle, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                    <ui:DropDownButton MinWidth="88" Appearance="Secondary" Content="{Binding MoreActionsText}" Icon="{ui:SymbolIcon Symbol=MoreHorizontal24}" Visibility="{Binding HasActionFlyout, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <ui:DropDownButton.Flyout>
                                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                                <MenuItem behaviors:ClickOpenSubmenuBehavior.IsEnabled="True" Header="{Binding OtherAttributesTitle}" Visibility="{Binding HasOtherAttributesSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <MenuItem Header="{Binding OnlyWithShiftLabel}" IsCheckable="True" IsChecked="{Binding OnlyWithShift, Mode=TwoWay}" IsEnabled="{Binding CanEditShellAttributes}" StaysOpenOnClick="True" />
                                                                    <MenuItem Header="{Binding OnlyInExplorerLabel}" IsCheckable="True" IsChecked="{Binding OnlyInExplorer, Mode=TwoWay}" IsEnabled="{Binding CanEditShellAttributes}" StaysOpenOnClick="True" />
                                                                    <MenuItem Header="{Binding NoWorkingDirectoryLabel}" IsCheckable="True" IsChecked="{Binding NoWorkingDirectory, Mode=TwoWay}" IsEnabled="{Binding CanEditShellAttributes}" StaysOpenOnClick="True" />
                                                                    <MenuItem Header="{Binding NeverDefaultLabel}" IsCheckable="True" IsChecked="{Binding NeverDefault, Mode=TwoWay}" IsEnabled="{Binding CanEditShellAttributes}" StaysOpenOnClick="True" />
                                                                    <MenuItem Header="{Binding ShowAsDisabledIfHiddenLabel}" IsCheckable="True" IsChecked="{Binding ShowAsDisabledIfHidden, Mode=TwoWay}" IsEnabled="{Binding CanEditShellAttributes}" StaysOpenOnClick="True" />
                                                                </MenuItem>
                                                                <MenuItem behaviors:ClickOpenSubmenuBehavior.IsEnabled="True" Header="{Binding DetailsTitle}" Visibility="{Binding HasDetailsActions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <MenuItem Command="{Binding EditUserNoteCommand}" Header="{Binding DetailsEditUserNoteLabel}" Visibility="{Binding CanEditUserNote, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                    <MenuItem Command="{Binding ChangeTextCommand}" Header="{Binding DetailsChangeTextLabel}" Visibility="{Binding CanEditText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                    <MenuItem Command="{Binding SearchOnlineCommand}" Header="{Binding DetailsSearchOnline}" Visibility="{Binding CanSearchOnline, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                    <MenuItem Command="{Binding ShowCommandTextCommand}" Header="{Binding DetailsCommandTextLabel}" Visibility="{Binding ShowReadOnlyCommandText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                    <MenuItem Command="{Binding ChangeCommandTextCommand}" Header="{Binding DetailsChangeCommandLabel}" Visibility="{Binding CanEditCommandText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                    <MenuItem Command="{Binding OpenFilePropertiesCommand}" Header="{Binding DetailsFilePropertiesLabel}" Visibility="{Binding HasFileLocation, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                    <MenuItem Command="{Binding OpenFileLocationCommand}" Header="{Binding DetailsFileLocationLabel}" Visibility="{Binding HasFileLocation, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                    <MenuItem Command="{Binding OpenRegistryLocationCommand}" Header="{Binding DetailsRegistryLocationLabel}" Visibility="{Binding HasRegistryLocation, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                    <MenuItem Command="{Binding ExportRegistryCommand}" Header="{Binding DetailsExportRegistryLabel}" Visibility="{Binding HasRegistryLocation, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                    <MenuItem Command="{Binding OpenClsidLocationCommand}" Header="{Binding DetailsClsidLocationLabel}" Visibility="{Binding HasClsidLocation, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                </MenuItem>
                                                            </ContextMenu>
                                                        </ui:DropDownButton.Flyout>
                                                    </ui:DropDownButton>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Page>
