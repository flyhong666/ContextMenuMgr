<UserControl
    x:Class="ContextMenuMgr.Frontend.Views.SpecialMenuContentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewModels="clr-namespace:ContextMenuMgr.Frontend.ViewModels"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource LayerFillColorAltBrush}" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <ui:TextBlock
                    FontSize="24"
                    FontWeight="SemiBold"
                    Text="{Binding Title}" />
                <ui:TextBlock
                    Margin="0,6,0,0"
                    Opacity="0.72"
                    Text="{Binding Description}"
                    TextWrapping="Wrap" />
                <StackPanel Margin="0,12,0,0">
                    <StackPanel
                        VerticalAlignment="Bottom"
                        DockPanel.Dock="Right"
                        Orientation="Horizontal">
                        <ui:ToggleSwitch
                            Margin="8,0,0,0"
                            IsChecked="{Binding IsShellNewOrderLocked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            ToolTip="{Binding LockNewMenuDescription}"
                            Visibility="{Binding ShowShellNewOrderLock, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:ToggleSwitch.Content>
                                <StackPanel MaxWidth="360">
                                    <ui:TextBlock Text="{Binding LockNewMenuText}" />
                                    <ui:TextBlock
                                        Margin="0,2,0,0"
                                        FontSize="12"
                                        Opacity="0.72"
                                        Text="{Binding LockNewMenuDescription}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </ui:ToggleSwitch.Content>
                        </ui:ToggleSwitch>
                        <Grid Margin="8,0,0,0" Visibility="{Binding ShowShellNewAclRepair, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:Flyout IsOpen="{Binding IsRepairShellNewAclFlyoutOpen, Mode=TwoWay}" Placement="Top">
                                <StackPanel Width="300">
                                    <ui:TextBlock Text="{Binding RepairShellNewAclConfirmationText}" TextWrapping="Wrap" />
                                    <StackPanel
                                        Margin="0,12,0,0"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal">
                                        <ui:Button
                                            Margin="0,0,8,0"
                                            Command="{Binding CloseRepairShellNewAclFlyoutCommand}"
                                            Content="{Binding CancelText}" />
                                        <ui:Button
                                            Appearance="Primary"
                                            Command="{Binding ConfirmRepairShellNewOrderAclCommand}"
                                            Content="{Binding RepairShellNewAclText}" />
                                    </StackPanel>
                                </StackPanel>
                            </ui:Flyout>
                            <ui:Button
                                Command="{Binding OpenRepairShellNewAclFlyoutCommand}"
                                Content="{Binding RepairShellNewAclText}"
                                Icon="{ui:SymbolIcon Symbol=Settings24}" />
                        </Grid>
                        <ui:Button
                            Margin="8,0,0,0"
                            Command="{Binding RestoreDefaultsCommand}"
                            Content="{Binding RestoreDefaultsText}"
                            Icon="{ui:SymbolIcon Symbol=ArrowReset24}"
                            Visibility="{Binding ShowRestoreDefaults, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <ui:Button
                            Margin="8,0,0,0"
                            Command="{Binding RefreshCommand}"
                            Content="{Binding RefreshText}"
                            Icon="{ui:SymbolIcon Symbol=ArrowSync24}" />
                        <ui:Button
                            Margin="8,0,0,0"
                            Command="{Binding AddCommand}"
                            Content="{Binding AddText}"
                            Icon="{ui:SymbolIcon Symbol=Add24}" />
                    </StackPanel>
                    <StackPanel>
                        <ui:TextBlock
                            Margin="0,0,0,6"
                            FontSize="12"
                            Opacity="0.72"
                            Text="{Binding SearchLabel}" />
                        <TextBox
                            MinWidth="260"
                            Padding="10,6"
                            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <StackPanel Margin="0,10,0,0" Visibility="{Binding ShowDropEffectSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:TextBlock
                                Margin="0,0,0,6"
                                FontSize="12"
                                Opacity="0.72"
                                Text="{Binding DropEffectLabel}" />
                            <ComboBox
                                MinWidth="180"
                                ItemsSource="{Binding DropEffectOptions}"
                                SelectedItem="{Binding SelectedDropEffect, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <ui:TextBlock
                    Margin="0,8,0,0"
                    Foreground="#C75000"
                    Text="{Binding StatusText}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" MinHeight="240">
            <ItemsControl ItemsSource="{Binding WinXGroups}" Visibility="{Binding ShowWinXTree, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.Resources>
                    <DataTemplate x:Key="WinXEntryTemplate" DataType="{x:Type viewModels:SpecialMenuItemViewModel}">
                        <Border
                            Margin="0,4,0,4"
                            Padding="10"
                            Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorSecondaryBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border
                                        Width="28"
                                        Height="28"
                                        Margin="0,0,10,0"
                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                        CornerRadius="6">
                                        <Image
                                            Width="20"
                                            Height="20"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Source="{Binding IconSource}" />
                                    </Border>
                                    <StackPanel>
                                        <ui:TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Text="{Binding DisplayName}" />
                                        <ui:TextBlock
                                            Margin="0,2,0,0"
                                            FontSize="11"
                                            Opacity="0.65"
                                            Text="{Binding Detail}"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding HasDetail, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Orientation="Horizontal">
                                    <ui:ToggleSwitch
                                        Margin="0,0,8,0"
                                        IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        IsEnabled="{Binding CanToggle}"
                                        Visibility="{Binding ShowToggle, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <ui:Button
                                        Width="32"
                                        Height="32"
                                        Margin="0,0,6,0"
                                        Padding="0"
                                        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Icon="{ui:SymbolIcon Symbol=Edit24}"
                                        IsEnabled="{Binding CanEdit}"
                                        ToolTip="{Binding DataContext.EditText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Visibility="{Binding ShowEdit, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <ui:Button
                                        Width="32"
                                        Height="32"
                                        Margin="0,0,6,0"
                                        Padding="0"
                                        Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Icon="{ui:SymbolIcon Symbol=ArrowUp24}"
                                        IsEnabled="{Binding CanMoveUp}"
                                        Visibility="{Binding ShowMove, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <ui:Button
                                        Width="32"
                                        Height="32"
                                        Margin="0,0,6,0"
                                        Padding="0"
                                        Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Icon="{ui:SymbolIcon Symbol=ArrowDown24}"
                                        IsEnabled="{Binding CanMoveDown}"
                                        Visibility="{Binding ShowMove, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <ui:Button
                                        Width="32"
                                        Height="32"
                                        Margin="0,0,6,0"
                                        Padding="0"
                                        Command="{Binding DataContext.UndoDeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Icon="{ui:SymbolIcon Symbol=ArrowUndo24}"
                                        IsEnabled="{Binding CanUndoDelete}"
                                        Visibility="{Binding ShowUndoDelete, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <Grid Visibility="{Binding ShowPermanentDelete, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ui:Button
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,6,0"
                                            Padding="0"
                                            Command="{Binding DataContext.OpenPermanentDeleteFlyoutCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Icon="{ui:SymbolIcon Symbol=DeleteDismiss24}"
                                            IsEnabled="{Binding CanPermanentlyDelete}" />
                                        <ui:Flyout IsOpen="{Binding IsPermanentDeleteFlyoutOpen, Mode=TwoWay}" Placement="Top">
                                            <StackPanel MinWidth="200">
                                                <ui:TextBlock
                                                    FontSize="14"
                                                    Text="{Binding PermanentDeleteConfirmationText}"
                                                    TextWrapping="Wrap" />
                                                <ui:TextBlock
                                                    Margin="0,8,0,0"
                                                    FontSize="12"
                                                    Opacity="0.65"
                                                    Text="{Binding DeletedAtText}" />
                                                <StackPanel
                                                    Margin="0,16,0,0"
                                                    HorizontalAlignment="Right"
                                                    Orientation="Horizontal">
                                                    <ui:Button
                                                        Margin="0,0,8,0"
                                                        Command="{Binding ClosePermanentDeleteFlyoutCommand}"
                                                        Content="{Binding DataContext.CancelText, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                    <ui:Button
                                                        Appearance="Danger"
                                                        Command="{Binding DataContext.ConfirmPermanentDeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="{Binding DataContext.PermanentDeleteText, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </ui:Flyout>
                                    </Grid>
                                    <ui:Button
                                        Width="32"
                                        Height="32"
                                        Padding="0"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Icon="{ui:SymbolIcon Symbol=Delete24}"
                                        IsEnabled="{Binding CanDelete}"
                                        Visibility="{Binding ShowDelete, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.Resources>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:WinXGroupNodeViewModel}">
                        <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <Expander.Header>
                                <Border
                                    Margin="0,6,0,6"
                                    Padding="10"
                                    BorderBrush="{DynamicResource CardStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Border
                                                Width="30"
                                                Height="30"
                                                Margin="0,0,10,0"
                                                Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                CornerRadius="6">
                                                <ui:SymbolIcon
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Symbol="Folder24" />
                                            </Border>
                                            <ui:TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Text="{Binding Group.DisplayName}" />
                                        </StackPanel>
                                        <StackPanel
                                            Grid.Column="1"
                                            Margin="12,0,0,0"
                                            Orientation="Horizontal">
                                            <ui:ToggleSwitch
                                                Margin="0,0,8,0"
                                                IsChecked="{Binding Group.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                IsEnabled="{Binding Group.CanToggle}"
                                                Visibility="{Binding Group.ShowToggle, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <ui:Button
                                                Width="32"
                                                Height="32"
                                                Margin="0,0,6,0"
                                                Padding="0"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Group}"
                                                Icon="{ui:SymbolIcon Symbol=Edit24}"
                                                IsEnabled="{Binding Group.CanEdit}"
                                                ToolTip="{Binding DataContext.EditText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Visibility="{Binding Group.ShowEdit, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <ui:Button
                                                Width="32"
                                                Height="32"
                                                Margin="0,0,6,0"
                                                Padding="0"
                                                Command="{Binding DataContext.UndoDeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Group}"
                                                Icon="{ui:SymbolIcon Symbol=ArrowUndo24}"
                                                IsEnabled="{Binding Group.CanUndoDelete}"
                                                Visibility="{Binding Group.ShowUndoDelete, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Grid Visibility="{Binding Group.ShowPermanentDelete, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <ui:Button
                                                    Width="32"
                                                    Height="32"
                                                    Margin="0,0,6,0"
                                                    Padding="0"
                                                    Command="{Binding DataContext.OpenPermanentDeleteFlyoutCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Group}"
                                                    Icon="{ui:SymbolIcon Symbol=DeleteDismiss24}"
                                                    IsEnabled="{Binding Group.CanPermanentlyDelete}" />
                                                <ui:Flyout IsOpen="{Binding Group.IsPermanentDeleteFlyoutOpen, Mode=TwoWay}" Placement="Top">
                                                    <StackPanel MinWidth="200">
                                                        <ui:TextBlock
                                                            FontSize="14"
                                                            Text="{Binding Group.PermanentDeleteConfirmationText}"
                                                            TextWrapping="Wrap" />
                                                        <ui:TextBlock
                                                            Margin="0,8,0,0"
                                                            FontSize="12"
                                                            Opacity="0.65"
                                                            Text="{Binding Group.DeletedAtText}" />
                                                        <StackPanel
                                                            Margin="0,16,0,0"
                                                            HorizontalAlignment="Right"
                                                            Orientation="Horizontal">
                                                            <ui:Button
                                                                Margin="0,0,8,0"
                                                                Command="{Binding Group.ClosePermanentDeleteFlyoutCommand}"
                                                                Content="{Binding DataContext.CancelText, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                            <ui:Button
                                                                Appearance="Danger"
                                                                Command="{Binding DataContext.ConfirmPermanentDeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding Group}"
                                                                Content="{Binding DataContext.PermanentDeleteText, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </ui:Flyout>
                                            </Grid>
                                            <ui:Button
                                                Width="32"
                                                Height="32"
                                                Padding="0"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Group}"
                                                Icon="{ui:SymbolIcon Symbol=Delete24}"
                                                IsEnabled="{Binding Group.CanDelete}"
                                                Visibility="{Binding Group.ShowDelete, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Expander.Header>
                            <ItemsControl
                                Margin="24,0,0,0"
                                ItemTemplate="{StaticResource WinXEntryTemplate}"
                                ItemsSource="{Binding Items}" />
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl ItemsSource="{Binding ItemsView}" Visibility="{Binding ShowWinXTree, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:SpecialMenuItemViewModel}">
                        <Border
                            Margin="0,0,0,10"
                            Padding="12"
                            Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorSecondaryBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid>
                                <ui:TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Opacity="0.72"
                                    Text="{Binding DisplayName}"
                                    Visibility="{Binding IsSeparator, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Grid>
                                    <Grid.Visibility>
                                        <Binding Converter="{StaticResource InverseBooleanToVisibilityConverter}" Path="IsSeparator" />
                                    </Grid.Visibility>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border
                                                Width="30"
                                                Height="30"
                                                Margin="0,0,10,0"
                                                Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                CornerRadius="6">
                                                <Image
                                                    Width="20"
                                                    Height="20"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Source="{Binding IconSource}" />
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <ui:TextBlock
                                                    FontSize="15"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding DisplayName}" />
                                                <ui:TextBlock
                                                    Margin="0,3,0,0"
                                                    FontFamily="Consolas"
                                                    FontSize="11"
                                                    Opacity="0.65"
                                                    Text="{Binding Subtitle}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                        <ui:TextBlock
                                            Margin="0,8,0,0"
                                            Opacity="0.72"
                                            Text="{Binding Detail}"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding HasDetail, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <ui:ToggleSwitch
                                            Margin="0,0,0,8"
                                            IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            IsEnabled="{Binding CanToggle}"
                                            Visibility="{Binding ShowToggle, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                            <ui:Button
                                                Width="32"
                                                Height="32"
                                                Margin="0,0,6,0"
                                                Padding="0"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Icon="{ui:SymbolIcon Symbol=Edit24}"
                                                IsEnabled="{Binding CanEdit}"
                                                ToolTip="{Binding DataContext.EditText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Visibility="{Binding ShowEdit, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <ui:Button
                                                Width="32"
                                                Height="32"
                                                Margin="0,0,6,0"
                                                Padding="0"
                                                Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Icon="{ui:SymbolIcon Symbol=ArrowUp24}"
                                                IsEnabled="{Binding CanMoveUp}"
                                                Visibility="{Binding ShowMove, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <ui:Button
                                                Width="32"
                                                Height="32"
                                                Margin="0,0,6,0"
                                                Padding="0"
                                                Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Icon="{ui:SymbolIcon Symbol=ArrowDown24}"
                                                IsEnabled="{Binding CanMoveDown}"
                                                Visibility="{Binding ShowMove, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <ui:Button
                                                Width="32"
                                                Height="32"
                                                Margin="0,0,6,0"
                                                Padding="0"
                                                Command="{Binding DataContext.UndoDeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Icon="{ui:SymbolIcon Symbol=ArrowUndo24}"
                                                IsEnabled="{Binding CanUndoDelete}"
                                                Visibility="{Binding ShowUndoDelete, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Grid Visibility="{Binding ShowPermanentDelete, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <ui:Button
                                                    Width="32"
                                                    Height="32"
                                                    Margin="0,0,6,0"
                                                    Padding="0"
                                                    Command="{Binding DataContext.OpenPermanentDeleteFlyoutCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Icon="{ui:SymbolIcon Symbol=DeleteDismiss24}"
                                                    IsEnabled="{Binding CanPermanentlyDelete}" />
                                                <ui:Flyout IsOpen="{Binding IsPermanentDeleteFlyoutOpen, Mode=TwoWay}" Placement="Top">
                                                    <StackPanel MinWidth="200">
                                                        <ui:TextBlock
                                                            FontSize="14"
                                                            Text="{Binding PermanentDeleteConfirmationText}"
                                                            TextWrapping="Wrap" />
                                                        <ui:TextBlock
                                                            Margin="0,8,0,0"
                                                            FontSize="12"
                                                            Opacity="0.65"
                                                            Text="{Binding DeletedAtText}" />
                                                        <StackPanel
                                                            Margin="0,16,0,0"
                                                            HorizontalAlignment="Right"
                                                            Orientation="Horizontal">
                                                            <ui:Button
                                                                Margin="0,0,8,0"
                                                                Command="{Binding ClosePermanentDeleteFlyoutCommand}"
                                                                Content="{Binding DataContext.CancelText, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                            <ui:Button
                                                                Appearance="Danger"
                                                                Command="{Binding DataContext.ConfirmPermanentDeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="{Binding DataContext.PermanentDeleteText, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </ui:Flyout>
                                            </Grid>
                                            <ui:Button
                                                Width="32"
                                                Height="32"
                                                Padding="0"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Icon="{ui:SymbolIcon Symbol=Delete24}"
                                                IsEnabled="{Binding CanDelete}"
                                                Visibility="{Binding ShowDelete, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border
                Padding="24,18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Panel.ZIndex="100"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                IsHitTestVisible="False"
                Visibility="{Binding ShowListPlaceholder, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel MinWidth="180" HorizontalAlignment="Center">
                    <ProgressBar
                        Width="120"
                        Height="4"
                        IsIndeterminate="True"
                        Visibility="{Binding IsListLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ui:SymbolIcon
                        Width="32"
                        Height="32"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Symbol="FolderOpen24"
                        Visibility="{Binding IsListEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ui:TextBlock
                        Margin="0,10,0,0"
                        HorizontalAlignment="Center"
                        FontSize="15"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Opacity="0.86">
                        <ui:TextBlock.Style>
                            <Style TargetType="ui:TextBlock">
                                <Setter Property="Text" Value="{Binding EmptyItemsText}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsListLoading}" Value="True">
                                        <Setter Property="Text" Value="{Binding LoadingItemsText}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:TextBlock.Style>
                    </ui:TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>