<UserControl
    x:Class="ContextMenuMgr.Frontend.Views.FileTypeBatchManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewModels="clr-namespace:ContextMenuMgr.Frontend.ViewModels"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="16"
            Background="{DynamicResource LayerFillColorAltBrush}"
            Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <DockPanel LastChildFill="True">
                        <Border
                            Width="32"
                            Height="32"
                            Margin="0,0,10,0"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="6"
                            DockPanel.Dock="Left">
                            <Image
                                Width="22"
                                Height="22"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Source="{Binding SourceItem.IconSource}"
                                Stretch="Uniform" />
                        </Border>
                        <ui:TextBlock
                            VerticalAlignment="Center"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Text="{Binding Title}"
                            TextTrimming="CharacterEllipsis" />
                    </DockPanel>
                    <ui:TextBlock
                        Margin="0,6,0,0"
                        Opacity="0.78"
                        Text="{Binding IdentityText}"
                        TextWrapping="Wrap" />
                    <ui:TextBlock
                        Margin="0,6,0,0"
                        Opacity="0.72"
                        Text="{Binding CountText}" />
                    <ui:TextBlock
                        Margin="0,10,0,0"
                        FontSize="12"
                        Opacity="0.65"
                        Text="{Binding SourceRegistryPathLabel}" />
                    <ui:TextBlock
                        Margin="0,2,0,0"
                        FontFamily="Consolas"
                        FontSize="11"
                        Opacity="0.72"
                        Text="{Binding SourceRegistryPath}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <WrapPanel
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    HorizontalAlignment="Right">
                    <ui:Button
                        Margin="0,0,8,8"
                        Padding="12,5"
                        Appearance="Secondary"
                        Command="{Binding BackCommand}"
                        Content="{Binding BackText}"
                        Icon="{ui:SymbolIcon Symbol=ArrowLeft24}" />
                    <ui:Button
                        Margin="0,0,8,8"
                        Padding="12,5"
                        Appearance="Secondary"
                        Command="{Binding RefreshCommand}"
                        Content="{Binding RefreshText}"
                        Icon="{ui:SymbolIcon Symbol=ArrowSync24}" />
                    <ui:Button
                        Margin="0,0,8,8"
                        Padding="12,5"
                        Command="{Binding DisableAllCommand}"
                        Content="{Binding DisableAllText}"
                        Icon="{ui:SymbolIcon Symbol=DismissCircle24}" />
                    <ui:Button
                        Margin="0,0,8,8"
                        Padding="12,5"
                        Command="{Binding EnableAllCommand}"
                        Content="{Binding EnableAllText}"
                        Icon="{ui:SymbolIcon Symbol=CheckmarkCircle24}" />
                    <ui:Button
                        Margin="0,0,0,8"
                        Padding="12,5"
                        Appearance="Secondary"
                        Command="{Binding DeleteAllCommand}"
                        Content="{Binding DeleteAllText}"
                        Icon="{ui:SymbolIcon Symbol=Delete24}" />
                    <ui:Button
                        Margin="8,0,0,8"
                        Padding="12,5"
                        Appearance="Secondary"
                        Command="{Binding UndoAllCommand}"
                        Content="{Binding UndoAllText}"
                        Icon="{ui:SymbolIcon Symbol=ArrowUndo24}" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <ListBox
                Background="Transparent"
                BorderThickness="0"
                ItemContainerStyle="{StaticResource ScrollableListBoxItemStyle}"
                ItemsSource="{Binding ItemsView}"
                ScrollViewer.CanContentScroll="True"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:ContextMenuItemViewModel}">
                        <Border
                            Margin="0,0,0,10"
                            Padding="12"
                            Background="{DynamicResource LayerFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorSecondaryBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Opacity="{Binding CardOpacity}">
                                    <WrapPanel>
                                        <ui:TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Text="{Binding DisplayName}" />
                                        <Border
                                            Margin="8,0,0,0"
                                            Padding="8,2"
                                            Background="{DynamicResource AccentFillColorSecondaryBrush}"
                                            CornerRadius="4">
                                            <ui:TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                            Text="{Binding StateLabel}" />
                                        </Border>
                                        <Border
                                            Margin="8,0,0,0"
                                            Padding="8,2"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            CornerRadius="4">
                                            <ui:TextBlock
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Text="{Binding FileTypeRegistrationSource}" />
                                        </Border>
                                    </WrapPanel>

                                    <ui:TextBlock
                                        Margin="0,3,0,0"
                                        FontSize="11"
                                        Opacity="0.62"
                                        Text="{Binding KeyName}"
                                        Visibility="{Binding ShowKeyName, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <ui:TextBlock
                                        Margin="0,6,0,0"
                                        FontFamily="Consolas"
                                        FontSize="11"
                                        Opacity="0.58"
                                        Text="{Binding RegistryPath}"
                                        TextWrapping="Wrap" />
                                    <ui:TextBlock
                                        Margin="0,6,0,0"
                                        FontFamily="Consolas"
                                        FontSize="11"
                                        Opacity="0.72"
                                        Text="{Binding InlineCommandText}"
                                        TextWrapping="Wrap"
                                        Visibility="{Binding ShowInlineCommandText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <ui:TextBlock
                                        Margin="0,6,0,0"
                                        Opacity="0.78"
                                        Text="{Binding Notes}"
                                        TextWrapping="Wrap"
                                        Visibility="{Binding ShowNotes, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    HorizontalAlignment="Right">
                                    <ui:ToggleSwitch
                                        MinWidth="72"
                                        Margin="0,0,0,8"
                                        Content="{Binding ToggleLabel}"
                                        IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        IsEnabled="{Binding CanToggle}"
                                        Visibility="{Binding ShowToggle, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <ui:Button
                                        MinWidth="88"
                                        Padding="12,5"
                                        Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Content="{Binding DataContext.DeleteText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Icon="{ui:SymbolIcon Symbol=Delete24}"
                                        IsEnabled="{Binding CanDeleteInFileTypeBatch}"
                                        ToolTip="{Binding DataContext.ProtectedDeleteText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Visibility="{Binding IsDeleted, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    <ui:Button
                                        MinWidth="88"
                                        Padding="12,5"
                                        Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Content="{Binding PrimaryActionLabel}"
                                        Icon="{ui:SymbolIcon Symbol=ArrowUndo24}"
                                        Visibility="{Binding IsDeleted, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel
                Margin="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding ShowPlaceholder, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ProgressBar
                    Width="220"
                    Height="4"
                    IsIndeterminate="True"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <ui:TextBlock
                    Margin="0,12,0,0"
                    Opacity="0.72"
                    Text="{Binding EmptyText}"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
