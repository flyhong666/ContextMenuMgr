<UserControl
    x:Class="ContextMenuMgr.Frontend.Views.FileTypeMenuAnalysisPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <Grid Margin="12,20,12,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Background="{DynamicResource LayerFillColorAltBrush}" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <ui:TextBlock
                    FontSize="22"
                    FontWeight="SemiBold"
                    Text="{Binding MenuAnalysisTitle}" />
                <ui:TextBlock
                    Margin="0,6,0,0"
                    Opacity="0.72"
                    Text="{Binding MenuAnalysisDescription}"
                    TextWrapping="Wrap" />
                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                    <ui:Button
                        Command="{Binding AnalyzeFileCommand}"
                        Content="{Binding AnalyzeFileText}"
                        Icon="{ui:SymbolIcon Symbol=DocumentSearch24}" />
                    <ui:Button
                        Margin="8,0,0,0"
                        Command="{Binding AnalyzeFolderCommand}"
                        Content="{Binding AnalyzeFolderText}"
                        Icon="{ui:SymbolIcon Symbol=SidebarSearchRtl20}" />
                </StackPanel>
            </StackPanel>
        </Border>
        <ItemsControl
            Grid.Row="1"
            Margin="0,12,0,0"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding AnalysisResults}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border
                        Margin="0,0,0,10"
                        Padding="12"
                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <DockPanel>
                            <ui:Button
                                Padding="12,5"
                                Command="{Binding DataContext.ApplyAnalysisResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Content="{Binding DataContext.JumpText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                DockPanel.Dock="Right"
                                Icon="{ui:SymbolIcon Symbol=ArrowRight24}" />
                            <StackPanel>
                                <ui:TextBlock
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Text="{Binding DisplayName}" />
                                <ui:TextBlock
                                    Margin="0,6,0,0"
                                    Opacity="0.72"
                                    Text="{Binding Reason}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
