<UserControl
    x:Class="ContextMenuMgr.Frontend.Views.Windows11ContextMenuPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewModels="clr-namespace:ContextMenuMgr.Frontend.ViewModels"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <Grid Margin="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource LayerFillColorAltBrush}" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <ui:TextBlock
                    FontSize="22"
                    FontWeight="SemiBold"
                    Text="{Binding Title}" />
                <ui:TextBlock
                    Margin="0,6,0,0"
                    Opacity="0.72"
                    Text="{Binding Description}"
                    TextWrapping="Wrap" />

                <ui:TextBlock Margin="0,14,0,0" Text="{Binding SearchLabel}" />

                <TextBox
                    Margin="0,8,0,0"
                    Padding="10,8"
                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <ListBox
                Margin="0,12,0,0"
                Background="Transparent"
                BorderThickness="0"
                ItemContainerStyle="{StaticResource ScrollableListBoxItemStyle}"
                ItemsSource="{Binding ItemsView}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:Windows11ContextMenuItemViewModel}">
                        <Border
                            Margin="0,0,0,10"
                            Padding="14"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border
                                            Width="38"
                                            Height="38"
                                            Margin="0,0,12,0"
                                            Background="{DynamicResource ControlFillColorQuarternaryBrush}"
                                            CornerRadius="10">
                                            <Grid>
                                                <Image
                                                    Width="24"
                                                    Height="24"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Source="{Binding LogoSource}"
                                                    Visibility="{Binding HasLogo, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <ui:SymbolIcon
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Symbol="AppsList24"
                                                    Visibility="{Binding HasLogo, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                            </Grid>
                                        </Border>

                                        <StackPanel VerticalAlignment="Center">
                                            <ui:TextBlock
                                                FontSize="17"
                                                FontWeight="SemiBold"
                                                Text="{Binding DisplayName}" />
                                            <ui:TextBlock
                                                Margin="0,4,0,0"
                                                Opacity="0.72"
                                                Text="{Binding PackageFamilyName}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <ui:TextBlock
                                        Margin="0,10,0,0"
                                        Opacity="0.72"
                                        Text="{Binding PublisherName}"
                                        Visibility="{Binding HasPublisherName, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <WrapPanel Margin="0,10,0,0">
                                        <Border
                                            Margin="0,0,8,8"
                                            Padding="8,2"
                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                            CornerRadius="4"
                                            Visibility="{Binding IsPendingApproval, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <ui:TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                Text="{Binding PendingApprovalText}" />
                                        </Border>
                                        <Border
                                            Margin="0,0,8,8"
                                            Padding="8,2"
                                            Background="{DynamicResource AccentFillColorSecondaryBrush}"
                                            CornerRadius="4">
                                            <ui:TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                Text="{Binding ContextTypesText}" />
                                        </Border>
                                        <Border
                                            Margin="0,0,8,8"
                                            Padding="8,2"
                                            Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                                            CornerRadius="4"
                                            Visibility="{Binding IsMachineBlocked, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <ui:TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Text="{Binding MachineBlockedText}" />
                                        </Border>
                                    </WrapPanel>

                                    <ui:TextBlock
                                        Margin="0,2,0,0"
                                        FontFamily="Consolas"
                                        FontSize="11"
                                        Opacity="0.68"
                                        Text="{Binding ComServerPath}"
                                        TextWrapping="Wrap"
                                        Visibility="{Binding HasComServerPath, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Margin="0,0,10,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                    <ui:ToggleSwitch
                                        Grid.Column="1"
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Right"
                                        IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        IsEnabled="{Binding CanToggle}"
                                        OffContent="{Binding ToggleOffText}"
                                        OnContent="{Binding ToggleOnText}" />
                                    <ui:Button
                                        Grid.Column="1"
                                        Margin="0,20,0,0"
                                        Appearance="Secondary"
                                        Command="{Binding OpenFileLocationCommand}"
                                        Content="{Binding OpenFileLocationText}"
                                        Icon="{ui:SymbolIcon Symbol=FolderOpen24}"
                                        IsEnabled="{Binding CanOpenFileLocation}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border
                Panel.ZIndex="100"
                Padding="24,18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                IsHitTestVisible="False"
                Visibility="{Binding ShowListPlaceholder, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" MinWidth="180">
                    <ProgressBar
                        Width="120"
                        Height="4"
                        IsIndeterminate="True"
                        Visibility="{Binding IsListLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ui:SymbolIcon
                        Width="32"
                        Height="32"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Symbol="FolderOpen24"
                        Visibility="{Binding IsListEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ui:TextBlock
                        Margin="0,10,0,0"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        FontSize="15"
                        Opacity="0.86">
                        <ui:TextBlock.Style>
                            <Style TargetType="ui:TextBlock">
                                <Setter Property="Text" Value="{Binding EmptyItemsText}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsListLoading}" Value="True">
                                        <Setter Property="Text" Value="{Binding LoadingItemsText}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:TextBlock.Style>
                    </ui:TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
