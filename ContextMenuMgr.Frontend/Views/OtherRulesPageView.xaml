<UserControl
    x:Class="ContextMenuMgr.Frontend.Views.OtherRulesPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewModels="clr-namespace:ContextMenuMgr.Frontend.ViewModels"
    xmlns:views="clr-namespace:ContextMenuMgr.Frontend.Views">
    <Grid>
        <TabControl Margin="0,8,0,0">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Star24" />
                        <TextBlock Text="{Binding EnhanceMenusTitle}" />
                    </StackPanel>
                </TabItem.Header>

                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{DynamicResource LayerFillColorAltBrush}" Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Margin="16,14,16,8">
                                <TextBlock
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Text="{Binding EnhanceMenusTitle}" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Opacity="0.72"
                                    Text="{Binding EnhanceMenusDescription}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <ui:ListView
                                Grid.Row="1"
                                BorderThickness="0"
                                ItemContainerStyle="{StaticResource DisplayOnlyListViewItemStyle}"
                                ItemsSource="{Binding EnhanceGroups}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                SelectedItem="{Binding SelectedEnhanceGroup}">
                                <ui:ListView.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:EnhanceMenuGroupViewModel}">
                                        <Border Padding="10">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="15"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Title}" />
                                                <TextBlock
                                                    Margin="0,6,0,0"
                                                    FontSize="11"
                                                    Opacity="0.68"
                                                    Text="{Binding RegistryPath}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ui:ListView.ItemTemplate>
                            </ui:ListView>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedEnhanceGroup}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Border Background="{DynamicResource LayerFillColorAltBrush}" Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="16,14,16,8">
                                    <TextBlock
                                        FontSize="22"
                                        FontWeight="SemiBold"
                                        Text="{Binding SelectedEnhanceGroup.Title}" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Opacity="0.72"
                                        Text="{Binding SelectedEnhanceGroup.RegistryPath}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <ItemsControl
                                    Grid.Row="1"
                                    Margin="12,0,12,12"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    ItemsSource="{Binding SelectedEnhanceGroup.Items}"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModels:EnhanceMenuItemViewModel}">
                                            <Border
                                                Margin="0,0,0,10"
                                                Padding="14"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Margin="0,0,16,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border
                                                                Width="32"
                                                                Height="32"
                                                                Margin="0,0,10,0"
                                                                Background="{DynamicResource ControlFillColorQuarternaryBrush}"
                                                                CornerRadius="8">
                                                                <Image
                                                                    Width="20"
                                                                    Height="20"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Source="{Binding IconSource}" />
                                                            </Border>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock
                                                                    FontSize="16"
                                                                    FontWeight="SemiBold"
                                                                    Text="{Binding DisplayName}" />
                                                                <TextBlock
                                                                    Margin="0,4,0,0"
                                                                    FontFamily="Consolas"
                                                                    FontSize="11"
                                                                    Opacity="0.68"
                                                                    Text="{Binding KeyName}" />
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <WrapPanel Margin="0,10,0,0">
                                                            <Border
                                                                Padding="8,2"
                                                                Background="{DynamicResource AccentFillColorSecondaryBrush}"
                                                                CornerRadius="4">
                                                                <TextBlock FontSize="11" Text="{Binding Kind}" />
                                                            </Border>
                                                        </WrapPanel>

                                                        <TextBlock
                                                            Margin="0,10,0,0"
                                                            Opacity="0.72"
                                                            Text="{Binding Tip}"
                                                            TextWrapping="Wrap"
                                                            Visibility="{Binding HasTip, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                    </StackPanel>

                                                    <ui:ToggleSwitch
                                                        Grid.Column="1"
                                                        Margin="0,4,0,0"
                                                        HorizontalAlignment="Right"
                                                        IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        IsEnabled="{Binding CanToggle}"
                                                        OffContent="{Binding ToggleOffText}"
                                                        OnContent="{Binding ToggleOnText}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>

                    <TextBlock
                        Grid.Column="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0.72"
                        Text="{Binding NoSelectionText}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedEnhanceGroup}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="DocumentEdit24" />
                        <TextBlock Text="{Binding DetailedEditTitle}" />
                    </StackPanel>
                </TabItem.Header>

                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{DynamicResource LayerFillColorAltBrush}" Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Margin="16,14,16,8">
                                <TextBlock
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Text="{Binding DetailedEditTitle}" />
                            </StackPanel>

                            <ui:ListView
                                Grid.Row="1"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemContainerStyle="{StaticResource DisplayOnlyListViewItemStyle}"
                                ItemsSource="{Binding DetailedEditGroups}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                SelectedItem="{Binding SelectedDetailedEditGroup}">
                                <ui:ListView.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:DetailedEditGroupViewModel}">
                                        <Border Padding="10">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="15"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Title}" />
                                                <TextBlock
                                                    Margin="0,6,0,0"
                                                    FontSize="11"
                                                    Opacity="0.68"
                                                    Text="{Binding RegistryPath}"
                                                    TextWrapping="Wrap"
                                                    Visibility="{Binding RegistryPath, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                                                <TextBlock
                                                    Margin="0,6,0,0"
                                                    FontSize="11"
                                                    Opacity="0.68"
                                                    Text="{Binding FilePath}"
                                                    TextWrapping="Wrap"
                                                    Visibility="{Binding FilePath, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ui:ListView.ItemTemplate>
                            </ui:ListView>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDetailedEditGroup}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Border Background="{DynamicResource LayerFillColorAltBrush}" Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="16,14,16,8">
                                    <TextBlock
                                        FontSize="22"
                                        FontWeight="SemiBold"
                                        Text="{Binding SelectedDetailedEditGroup.Title}" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Opacity="0.72"
                                        Text="{Binding SelectedDetailedEditGroup.RegistryPath}"
                                        TextWrapping="Wrap"
                                        Visibility="{Binding SelectedDetailedEditGroup.RegistryPath, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Opacity="0.72"
                                        Text="{Binding SelectedDetailedEditGroup.FilePath}"
                                        TextWrapping="Wrap"
                                        Visibility="{Binding SelectedDetailedEditGroup.FilePath, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                                </StackPanel>

                                <ItemsControl
                                    Grid.Row="1"
                                    Margin="12,0,12,12"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    ItemsSource="{Binding SelectedDetailedEditGroup.Rules}"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModels:DetailedEditRuleViewModel}">
                                            <Border
                                                Margin="0,0,0,10"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                Style="{StaticResource CardBorderStyle}">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="15"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding DisplayName}" />
                                                    <TextBlock
                                                        Margin="0,6,0,0"
                                                        Opacity="0.72"
                                                        Text="{Binding Tip}"
                                                        TextWrapping="Wrap"
                                                        Visibility="{Binding Tip, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                                                    <Border
                                                        Margin="0,8,0,0"
                                                        Padding="8,2"
                                                        Background="{DynamicResource AccentFillColorSecondaryBrush}"
                                                        CornerRadius="4"
                                                        Visibility="{Binding RequiresExplorerRestart, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock FontSize="11" Text="{Binding RestartExplorerHint}" />
                                                    </Border>

                                                    <ui:ToggleSwitch
                                                        Margin="0,12,0,0"
                                                        Content="{Binding DisplayName}"
                                                        IsChecked="{Binding BoolValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        Visibility="{Binding IsBooleanRule, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                    <DockPanel Margin="0,12,0,0" Visibility="{Binding IsNumberRule, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBox
                                                            MinWidth="140"
                                                            Margin="0,0,8,0"
                                                            Padding="10,6"
                                                            DockPanel.Dock="Left"
                                                            Text="{Binding NumberText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <ui:Button
                                                            Padding="14,6"
                                                            Command="{Binding ApplyCommand}"
                                                            Content="{Binding ApplyText}"
                                                            Icon="{ui:SymbolIcon Symbol=Checkmark24}" />
                                                    </DockPanel>

                                                    <DockPanel Margin="0,12,0,0" Visibility="{Binding IsStringRule, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBox
                                                            MinWidth="260"
                                                            Margin="0,0,8,0"
                                                            Padding="10,6"
                                                            DockPanel.Dock="Left"
                                                            Text="{Binding StringValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <ui:Button
                                                            Padding="14,6"
                                                            Command="{Binding ApplyCommand}"
                                                            Content="{Binding ApplyText}"
                                                            Icon="{ui:SymbolIcon Symbol=Checkmark24}" />
                                                    </DockPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>

                    <TextBlock
                        Grid.Column="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0.72"
                        Text="{Binding NoSelectionText}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDetailedEditGroup}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="TextNumberListLtr24" />
                        <TextBlock Text="{Binding CustomRegistryPathTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <views:SceneBrowserView DataContext="{Binding CustomRegistryPathTab}" />
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="CursorHover24" />
                        <TextBlock Text="{Binding DragDropTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <views:SpecialMenuPageView DataContext="{Binding DragDropTab}" />
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Library24" />
                        <TextBlock Text="{Binding CommandStoreTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <views:SpecialMenuPageView DataContext="{Binding CommandStoreTab}" />
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="DismissCircle24" />
                        <TextBlock Text="{Binding GuidBlockTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <views:SpecialMenuPageView DataContext="{Binding GuidBlockTab}" />
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Globe24" />
                        <TextBlock Text="{Binding IeMenuTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <views:SpecialMenuPageView DataContext="{Binding IeMenuTab}" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
