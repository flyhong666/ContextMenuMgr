<UserControl
    x:Class="ContextMenuMgr.Frontend.Views.OtherRulesPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewModels="clr-namespace:ContextMenuMgr.Frontend.ViewModels"
    xmlns:views="clr-namespace:ContextMenuMgr.Frontend.Views"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <UserControl.Resources>
        <Style x:Key="OtherRulesTabHostSurfaceStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="{DynamicResource LayerFillColorAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="OtherRulesTabContentSurfaceStyle" TargetType="Border">
            <Setter Property="Margin" Value="12" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="OtherRulesLeftPanelStyle" BasedOn="{StaticResource CardBorderStyle}" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        </Style>

        <Style x:Key="OtherRulesRightPanelStyle" BasedOn="{StaticResource CardBorderStyle}" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource LayerFillColorAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
        </Style>

        <Style x:Key="OtherRulesScrollViewportStyle" TargetType="Border">
            <Setter Property="Margin" Value="12,0,12,12" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorQuarternaryBrush}" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="OtherRulesItemCardStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Style="{StaticResource OtherRulesTabHostSurfaceStyle}">
        <!-- Named for code-behind tab selection tracking to toggle outer ScrollViewer -->
        <TabControl x:Name="MainTabControl" Background="Transparent">
            <TabItem Tag="EnhanceMenus">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Star24" />
                        <ui:TextBlock Text="{Binding EnhanceMenusTitle}" />
                    </StackPanel>
                </TabItem.Header>

                <Border Style="{StaticResource OtherRulesTabContentSurfaceStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource OtherRulesLeftPanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Margin="16,14,16,8">
                                <ui:TextBlock
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Text="{Binding EnhanceMenusTitle}" />
                                <ui:TextBlock
                                    Margin="0,6,0,0"
                                    Opacity="0.72"
                                    Text="{Binding EnhanceMenusDescription}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <ui:ListView
                                Grid.Row="1"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemContainerStyle="{StaticResource DisplayOnlyListViewItemStyle}"
                                ItemsSource="{Binding EnhanceGroups}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                SelectedItem="{Binding SelectedEnhanceGroup}">
                                <ui:ListView.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:EnhanceMenuGroupViewModel}">
                                        <Border Padding="10">
                                            <StackPanel>
                                                <ui:TextBlock
                                                    FontSize="15"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Title}" />
                                                <ui:TextBlock
                                                    Margin="0,6,0,0"
                                                    FontSize="11"
                                                    Opacity="0.68"
                                                    Text="{Binding RegistryPath}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ui:ListView.ItemTemplate>
                            </ui:ListView>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedEnhanceGroup}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Border Style="{StaticResource OtherRulesRightPanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="16,14,16,8">
                                    <ui:TextBlock
                                        FontSize="22"
                                        FontWeight="SemiBold"
                                        Text="{Binding SelectedEnhanceGroup.Title}" />
                                    <ui:TextBlock
                                        Margin="0,6,0,0"
                                        Opacity="0.72"
                                        Text="{Binding SelectedEnhanceGroup.RegistryPath}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- ScrollViewer wrapping ItemsControl for independent right-panel scrolling.
                                     ItemsControl has no built-in ScrollViewer, so we wrap it explicitly.
                                     The outer DynamicScrollViewer is disabled in code-behind for this tab. -->
                                <Border
                                    Grid.Row="1"
                                    Style="{StaticResource OtherRulesScrollViewportStyle}">
                                    <ScrollViewer
                                        HorizontalScrollBarVisibility="Disabled"
                                        VerticalScrollBarVisibility="Auto">
                                        <ItemsControl
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ItemsSource="{Binding SelectedEnhanceGroup.Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type viewModels:EnhanceMenuItemViewModel}">
                                                    <Border Style="{StaticResource OtherRulesItemCardStyle}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Margin="0,0,16,0">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Border
                                                                        Width="32"
                                                                        Height="32"
                                                                        Margin="0,0,10,0"
                                                                        Background="{DynamicResource ControlFillColorQuarternaryBrush}"
                                                                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8">
                                                                        <Image
                                                                            Width="20"
                                                                            Height="20"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            Source="{Binding IconSource}" />
                                                                    </Border>
                                                                    <StackPanel VerticalAlignment="Center">
                                                                        <ui:TextBlock
                                                                            FontSize="16"
                                                                            FontWeight="SemiBold"
                                                                            Text="{Binding DisplayName}" />
                                                                        <ui:TextBlock
                                                                            Margin="0,4,0,0"
                                                                            FontFamily="Consolas"
                                                                            FontSize="11"
                                                                            Opacity="0.68"
                                                                            Text="{Binding KeyName}" />
                                                                    </StackPanel>
                                                                </StackPanel>

                                                                <WrapPanel Margin="0,10,0,0">
                                                                    <Border
                                                                        Padding="8,2"
                                                                        Background="{DynamicResource AccentFillColorSecondaryBrush}"
                                                                        CornerRadius="4">
                                                                        <ui:TextBlock
                                                                            FontSize="11"
                                                                            Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                                            Text="{Binding Kind}" />
                                                                    </Border>
                                                                </WrapPanel>

                                                                <ui:TextBlock
                                                                    Margin="0,10,0,0"
                                                                    Opacity="0.72"
                                                                    Text="{Binding Tip}"
                                                                    TextWrapping="Wrap"
                                                                    Visibility="{Binding HasTip, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                            </StackPanel>

                                                            <ui:ToggleSwitch
                                                                Grid.Column="1"
                                                                Margin="0,4,0,0"
                                                                HorizontalAlignment="Right"
                                                                IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                IsEnabled="{Binding CanToggle}"
                                                                OffContent="{Binding ToggleOffText}"
                                                                OnContent="{Binding ToggleOnText}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <ui:TextBlock
                        Grid.Column="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0.72"
                        Text="{Binding NoSelectionText}">
                        <ui:TextBlock.Style>
                            <Style TargetType="ui:TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedEnhanceGroup}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:TextBlock.Style>
                    </ui:TextBlock>
                </Grid>
                </Border>
            </TabItem>

            <TabItem Tag="DetailedEdit">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="DocumentEdit24" />
                        <ui:TextBlock Text="{Binding DetailedEditTitle}" />
                    </StackPanel>
                </TabItem.Header>

                <Border Style="{StaticResource OtherRulesTabContentSurfaceStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource OtherRulesLeftPanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Margin="16,14,16,8">
                                <ui:TextBlock
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Text="{Binding DetailedEditTitle}" />
                            </StackPanel>

                            <ui:ListView
                                Grid.Row="1"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemContainerStyle="{StaticResource DisplayOnlyListViewItemStyle}"
                                ItemsSource="{Binding DetailedEditGroups}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                SelectedItem="{Binding SelectedDetailedEditGroup}">
                                <ui:ListView.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:DetailedEditGroupViewModel}">
                                        <Border Padding="10">
                                            <StackPanel>
                                                <ui:TextBlock
                                                    FontSize="15"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Title}" />
                                                <ui:TextBlock
                                                    Margin="0,6,0,0"
                                                    FontSize="11"
                                                    Opacity="0.68"
                                                    Text="{Binding RegistryPath}"
                                                    TextWrapping="Wrap"
                                                    Visibility="{Binding RegistryPath, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                                                <ui:TextBlock
                                                    Margin="0,6,0,0"
                                                    FontSize="11"
                                                    Opacity="0.68"
                                                    Text="{Binding FilePath}"
                                                    TextWrapping="Wrap"
                                                    Visibility="{Binding FilePath, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ui:ListView.ItemTemplate>
                            </ui:ListView>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDetailedEditGroup}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Border Style="{StaticResource OtherRulesRightPanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="16,14,16,8">
                                    <ui:TextBlock
                                        FontSize="22"
                                        FontWeight="SemiBold"
                                        Text="{Binding SelectedDetailedEditGroup.Title}" />
                                    <ui:TextBlock
                                        Margin="0,6,0,0"
                                        Opacity="0.72"
                                        Text="{Binding SelectedDetailedEditGroup.RegistryPath}"
                                        TextWrapping="Wrap"
                                        Visibility="{Binding SelectedDetailedEditGroup.RegistryPath, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                                    <ui:TextBlock
                                        Margin="0,6,0,0"
                                        Opacity="0.72"
                                        Text="{Binding SelectedDetailedEditGroup.FilePath}"
                                        TextWrapping="Wrap"
                                        Visibility="{Binding SelectedDetailedEditGroup.FilePath, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                                </StackPanel>

                                <!-- ScrollViewer wrapping ItemsControl for independent right-panel scrolling.
                                     ItemsControl has no built-in ScrollViewer, so we wrap it explicitly.
                                     The outer DynamicScrollViewer is disabled in code-behind for this tab. -->
                                <Border
                                    Grid.Row="1"
                                    Style="{StaticResource OtherRulesScrollViewportStyle}">
                                    <ScrollViewer
                                        HorizontalScrollBarVisibility="Disabled"
                                        VerticalScrollBarVisibility="Auto">
                                        <ItemsControl
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ItemsSource="{Binding SelectedDetailedEditGroup.Rules}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type viewModels:DetailedEditRuleViewModel}">
                                                    <Border Style="{StaticResource OtherRulesItemCardStyle}">
                                                        <StackPanel>
                                                            <ui:TextBlock
                                                                FontSize="15"
                                                                FontWeight="SemiBold"
                                                                Text="{Binding DisplayName}" />
                                                            <ui:TextBlock
                                                                Margin="0,6,0,0"
                                                                Opacity="0.72"
                                                                Text="{Binding Tip}"
                                                                TextWrapping="Wrap"
                                                                Visibility="{Binding Tip, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                                                            <Border
                                                                Margin="0,8,0,0"
                                                                Padding="8,2"
                                                                Background="{DynamicResource AccentFillColorSecondaryBrush}"
                                                                CornerRadius="4"
                                                                Visibility="{Binding RequiresExplorerRestart, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <ui:TextBlock
                                                                    FontSize="11"
                                                                    Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                                    Text="{Binding RestartExplorerHint}" />
                                                            </Border>

                                                            <ui:ToggleSwitch
                                                                Margin="0,12,0,0"
                                                                Content="{Binding DisplayName}"
                                                                IsChecked="{Binding BoolValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                Visibility="{Binding IsBooleanRule, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                            <DockPanel Margin="0,12,0,0" Visibility="{Binding IsNumberRule, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <TextBox
                                                                    MinWidth="140"
                                                                    Margin="0,0,8,0"
                                                                    Padding="10,6"
                                                                    DockPanel.Dock="Left"
                                                                    Text="{Binding NumberText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                <ui:Button
                                                                    Padding="14,6"
                                                                    Command="{Binding ApplyCommand}"
                                                                    Content="{Binding ApplyText}"
                                                                    Icon="{ui:SymbolIcon Symbol=Checkmark24}" />
                                                            </DockPanel>

                                                            <DockPanel Margin="0,12,0,0" Visibility="{Binding IsStringRule, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <TextBox
                                                                    MinWidth="260"
                                                                    Margin="0,0,8,0"
                                                                    Padding="10,6"
                                                                    DockPanel.Dock="Left"
                                                                    Text="{Binding StringValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                <ui:Button
                                                                    Padding="14,6"
                                                                    Command="{Binding ApplyCommand}"
                                                                    Content="{Binding ApplyText}"
                                                                    Icon="{ui:SymbolIcon Symbol=Checkmark24}" />
                                                            </DockPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <ui:TextBlock
                        Grid.Column="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0.72"
                        Text="{Binding NoSelectionText}">
                        <ui:TextBlock.Style>
                            <Style TargetType="ui:TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDetailedEditGroup}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:TextBlock.Style>
                    </ui:TextBlock>
                </Grid>
                </Border>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="TextNumberListLtr24" />
                        <ui:TextBlock Text="{Binding CustomRegistryPathTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Border Style="{StaticResource OtherRulesTabContentSurfaceStyle}">
                    <views:SceneBrowserView DataContext="{Binding CustomRegistryPathTab}" />
                </Border>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="CursorHover24" />
                        <ui:TextBlock Text="{Binding DragDropTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Border Style="{StaticResource OtherRulesTabContentSurfaceStyle}">
                    <views:SpecialMenuPageView DataContext="{Binding DragDropTab}" />
                </Border>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Library24" />
                        <ui:TextBlock Text="{Binding CommandStoreTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Border Style="{StaticResource OtherRulesTabContentSurfaceStyle}">
                    <views:SpecialMenuPageView DataContext="{Binding CommandStoreTab}" />
                </Border>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="DismissCircle24" />
                        <ui:TextBlock Text="{Binding GuidBlockTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Border Style="{StaticResource OtherRulesTabContentSurfaceStyle}">
                    <views:SpecialMenuPageView DataContext="{Binding GuidBlockTab}" />
                </Border>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Globe24" />
                        <ui:TextBlock Text="{Binding IeMenuTab.Title}" />
                    </StackPanel>
                </TabItem.Header>
                <Border Style="{StaticResource OtherRulesTabContentSurfaceStyle}">
                    <views:SpecialMenuPageView DataContext="{Binding IeMenuTab}" />
                </Border>
            </TabItem>
        </TabControl>
        </Border>
    </Grid>
</UserControl>
